# Copy to `.env` and fill in the values that apply to you. `.env` is
# gitignored and docker-compose automatically loads it.
#
# Three possible setups, from most preferred to least:
#
#   A) Bedrock unlocked (workshop admin lifted the deny)
#      Fill the BEDROCK_* block below.
#
#   B) Bedrock blocked, Anthropic credits available
#      Leave BEDROCK_* empty, set ANTHROPIC_API_KEY. Query understanding +
#      explanations go direct to Anthropic. Embeddings use local model.
#
#   C) Nothing cloud at all
#      Leave everything empty. Query understanding uses the heuristic
#      fallback. Embeddings use local BGE-M3. BM25 works regardless.
#
# BM25 never needs any API keys.

# ---- A) Bedrock (workshop account) ---------------------------------------
# Get these from Workshop Studio → "Get AWS CLI credentials".
# STS tokens expire every 4-8h — refresh this block when you get ExpiredToken.
BEDROCK_AWS_ACCESS_KEY_ID=
BEDROCK_AWS_SECRET_ACCESS_KEY=
BEDROCK_AWS_SESSION_TOKEN=
BEDROCK_AWS_REGION=us-west-2

# Default model IDs. Our workshop account offers Sonnet 4 only via the
# global inference profile — prefix with "global." or "us." accordingly.
BEDROCK_QUERY_UNDERSTANDING_MODEL_ID=global.anthropic.claude-sonnet-4-20250514-v1:0
BEDROCK_EMBEDDING_MODEL_ID=cohere.embed-multilingual-v3
BEDROCK_EXPLANATION_MODEL_ID=us.anthropic.claude-3-5-haiku-20241022-v1:0

# Set to "1" to force the non-Bedrock path even if Bedrock is configured
# (useful for local dev / A-B testing the fallback).
FORCE_BEDROCK_FALLBACK=0

# ---- B) Anthropic direct (fallback for Claude) ---------------------------
# Used when Bedrock is blocked or FORCE_BEDROCK_FALLBACK=1.
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_ID=claude-sonnet-4-20250514

# ---- C) Local embeddings (fallback for Cohere) ---------------------------
# Set to "1" to always use the local model even if Bedrock works. When 0,
# the local model is only used if Bedrock is unreachable. fastembed
# downloads BAAI/bge-m3 (~2.3 GB) on first use and caches it.
USE_LOCAL_EMBEDDINGS=0
# multilingual-e5-large: 1024-d, 100+ langs, ~2.2 GB. Matches our EMBED_DIM=1024.
#   GPU (RTX 4060): ~400 docs/s → all 22k in ~1 min.
#   CPU: ~0.6 docs/s → ~10h (avoid).
# mpnet-base-v2 (768-d, ~40 docs/s on CPU) is a slower-but-CPU-friendly fallback
# if no GPU is available — but then remember to reduce EMBED_DIM in code.
LOCAL_EMBEDDING_MODEL=intfloat/multilingual-e5-large

# ---- D) S3 bootstrap (pull artifacts on `docker compose up`) -------------
# The `bootstrap` service runs before `api`/`mcp` and pulls listings.db,
# bm25.pkl, geo cache, and VLM shards from this bucket. Skips files that
# already exist; set BOOTSTRAP_FORCE=1 to re-sync.
#
# AWS credentials come from the BEDROCK_* or AWS_* block above (workshop
# account). Leaving the session token empty is fine if using long-lived keys.
ARTIFACTS_S3_BUCKET=datathon-robinreal-085455950306-us-west-2
ARTIFACTS_S3_REGION=us-west-2

# Also download the ~30k raw image files (big, ~several GB). The app itself
# doesn't need these for ranking — only set to 1 if you want them on disk
# for e.g. re-embedding or local inspection. Otherwise view via presigned
# URLs from image_urls.py.
BOOTSTRAP_INCLUDE_IMAGES=0
BOOTSTRAP_FORCE=0

# Credentials for the artifacts bucket. If your workshop creds are short-lived
# STS tokens, keep them refreshed here. (These are also used by the app
# container itself, not just bootstrap.)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-west-2
